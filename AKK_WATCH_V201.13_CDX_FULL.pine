//@version=5
// =============================================================================
// AKK_WATCH_V201.13_CDX_FULL
// FIX #1  : Stop ratchet (stop asla aşağı gevşemez)
// FIX #2  : Short-Ralli simetrik trail eklendi
// FIX #3  : PUSU R:R initialStop ile hesaplanıyor
// FIX #4  : Exit etiketinde realFill notu
// FIX #5  : calc_on_every_tick=false + dataHigh/dataLow tutarlılık
// FIX #6  : initialStop tracking → R_initial / R_current ayrımı
// FIX #7  : TP1 hit etiketi eklendi
// FIX #8  : smartStop mesafe sınırı (1.5×riskUnit)
// FIX #9  : Aynı barda stop+target → açılış bazlı heuristik
// FIX #10 : PUSU exit loglama (TP2/STOP/TIMEOUT ayrımı)
// =============================================================================

strategy("AKK_WATCH_V201.13_CDX_FULL", overlay=true, calc_on_every_tick=false, process_orders_on_close=false, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000, currency=currency.USD, max_labels_count=500, max_lines_count=500)
// =============================================================================
// BÖLÜM 0: ADAPTİF ZEKA (ZAMAN x PİYASA)
// =============================================================================

// --- 1. ZAMAN PROFİLİ (Timeframe Profile) ---
int tfSeconds = timeframe.in_seconds(timeframe.period)

var string tfName        = "GENEL"
var float  tf_BaseRisk   = 1.5
var float  tf_ReducedRisk= 0.5
var int    tf_AdxThresh  = 25
var float  tf_TargetR    = 4.0
var int    tf_BreakLen   = 14
var float  tf_Mesafe     = 6.0
var float  tf_VolThresh  = 2.0

if tfSeconds <= 3600
    tfName         := "🛡️ SNIPER (1H)"
    tf_BaseRisk    := 1.0
    tf_ReducedRisk := 0.25
    tf_AdxThresh   := 30
    tf_TargetR     := 3.0
    tf_BreakLen    := 20
    tf_Mesafe      := 4.0
    tf_VolThresh   := 1.8
else if tfSeconds <= 14400
    tfName         := "⚖️ BALANCED (4H)"
    tf_BaseRisk    := 1.5
    tf_ReducedRisk := 0.5
    tf_AdxThresh   := 25
    tf_TargetR     := 3.5
    tf_BreakLen    := 14
    tf_Mesafe      := 6.0
    tf_VolThresh   := 2.0
else
    tfName         := "👑 TREND KING (8H+)"
    tf_BaseRisk    := 2.0
    tf_ReducedRisk := 1.0
    tf_AdxThresh   := 20
    tf_TargetR     := 5.0
    tf_BreakLen    := 10
    tf_Mesafe      := 8.0
    tf_VolThresh   := 2.5

// --- MARKET PROFİL OVERRIDE (INPUTS) ---
group_market = "MARKET PROFİL OVERRIDE"
useMarketOverride = input.bool(false, "Market Profil Override Aktif mi?", group=group_market)
useSilverProfile  = input.bool(true,  "XAG (Silver) Özel Profil Aktif", group=group_market)

inp_market_TargetMult  = input.float(1.0, "Market Target Mult", group=group_market, step=0.1)
inp_market_RiskMult    = input.float(1.0, "Market Risk Mult", group=group_market, step=0.1)
inp_market_AdxAdd      = input.int(0, "Market ADX Add", group=group_market, minval=-20, maxval=20)
inp_market_StopAtrMult = input.float(1.0, "Market StopATR Mult", group=group_market, step=0.1)

// --- 2. PİYASA PROFİLİ (Market Profile) ---
bool isCrypto = (syminfo.type == "crypto") or str.contains(syminfo.ticker, "USDT")
bool isForex  = (syminfo.type == "forex")
bool isIndex  = (syminfo.type == "index") or (syminfo.type == "cfd" and (str.contains(syminfo.ticker, "NAS") or str.contains(syminfo.ticker, "SPX") or str.contains(syminfo.ticker, "GER") or str.contains(syminfo.ticker, "US30")))
bool isStock  = (syminfo.type == "stock")
bool isSilver = str.contains(str.upper(syminfo.ticker), "XAG") or str.contains(str.upper(syminfo.ticker), "SILVER")

float market_TargetMult  = 1.0
float market_RiskMult    = 1.0
int   market_AdxAdd      = 0
float market_StopAtrMult = 1.0
string marketName        = "EMTIA/GENEL"

if isCrypto
    marketName        := "KRİPTO 🎢"
    market_TargetMult := 1.5
    market_RiskMult   := 0.8
    market_AdxAdd     := 5
else if isForex
    marketName        := "FOREX 💱"
    market_TargetMult := 0.8
    market_AdxAdd     := -5
else if isIndex or isStock
    marketName        := "ENDEKS/HİSSE 📈"
    market_StopAtrMult:= 1.5
else if isSilver and useSilverProfile
    marketName        := "GÜMÜŞ ⚙️"
    market_TargetMult := 1.1
    market_RiskMult   := 0.9
    market_AdxAdd     := 5
    market_StopAtrMult:= 1.2

// --- SEMBOL + TF OVERRIDE (AUTO) ---
string symbolKey = str.upper(syminfo.ticker)
string tfKey = tfSeconds <= 1800 ? "30" : tfSeconds <= 3600 ? "60" : tfSeconds <= 14400 ? "240" : "D+"

bool hasSymbolTfOverride = false
float sym_TargetMult = na
float sym_RiskMult = na
int   sym_AdxAdd = na
float sym_StopAtrMult = na

if symbolKey == "XAUUSD"
    if tfKey == "30"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.0
        sym_RiskMult := 1.0
        sym_AdxAdd := 0
        sym_StopAtrMult := 1.0
    else if tfKey == "60"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.0
        sym_RiskMult := 1.0
        sym_AdxAdd := 0
        sym_StopAtrMult := 1.0
    else if tfKey == "240"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.0
        sym_RiskMult := 1.0
        sym_AdxAdd := 0
        sym_StopAtrMult := 1.0

