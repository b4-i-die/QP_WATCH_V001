            table.cell(mainPanel, 0, r, "PİYASA", text_color=color.gray, text_size=fSize)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, marketName, text_color=color.white, text_size=fSize, bgcolor=mktBgS)
            r += 1

            table.cell(mainPanel, 0, r, "ANA TREND", text_color=color.gray, text_size=fSize)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, trendTextShort, text_color=trendColorShort, text_size=fSize, bgcolor=color.new(trendColorShort, 85))
            r += 1

            table.cell(mainPanel, 0, r, "REJİM", text_color=color.gray, text_size=fSize)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, marketRegimeText, text_color=regimeColor, text_size=fSize)
            r += 1

        table.merge_cells(mainPanel, 0, r, 3, r)
        table.cell(mainPanel, 0, r, "🔻 SHORT (OPSİYONEL)", text_color=color.silver, bgcolor=color.new(#363a45, 0), text_size=size.small)
        r += 1

        bool shortActive = inTradeRalliShort or inPositionPusuShort
        string shortStatus = inTradeRalliShort ? "RALLİ SHORT AKTİF" : inPositionPusuShort ? "PUSU SHORT AKTİF" : "PASİF / BEKLEME"

        table.cell(mainPanel, 0, r, "SHORT DURUM", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, shortStatus, text_color=shortActive ? color.red : color.yellow, text_size=fSize)
        r += 1

        float shortEntry = inTradeRalliShort ? entryRalliShort : inPositionPusuShort ? pusuLevelShort : na
        float shortStop  = inTradeRalliShort ? stopRalliShort  : inPositionPusuShort ? activeSlShort  : na
        float shortTP    = inTradeRalliShort ? targetRalliShort : inPositionPusuShort ? trackedT2Short : na

        table.cell(mainPanel, 0, r, "SHORT GİRİŞ", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, shortActive ? str.tostring(nz(shortEntry), priceFormat) : "-", text_color=color.white, text_size=fSize)
        r += 1

        table.cell(mainPanel, 0, r, "SHORT STOP", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, shortActive ? str.tostring(nz(shortStop), priceFormat) : "-", text_color=color.red, text_size=fSize)
        r += 1

        table.cell(mainPanel, 0, r, "SHORT HEDEF", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, shortActive ? str.tostring(nz(shortTP), priceFormat) : "-", text_color=color.green, text_size=fSize)
        r += 1

        table.cell(mainPanel, 0, r, "SHORT R:R", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, str.tostring(rr1Short, "#.##") + " / " + str.tostring(dynamicRrThresh, "#.##"), text_color=rrOkShort ? color.white : color.red, text_size=fSize)
        r += 1

        table.cell(mainPanel, 0, r, "SHORT SKOR", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, str.tostring(confidenceShort, "#") + "% / " + str.tostring(scoreReqShort, "#"), text_color=confidenceShort >= scoreReqShort ? color.green : color.red, text_size=fSize)
        r += 1

        // SHORT MENTOR (Trade aktifken)
        if inTradeRalliShort
            table.merge_cells(mainPanel, 0, r, 3, r)
            table.cell(mainPanel, 0, r, "--- 🎓 SHORT MENTOR ---", text_color=color.yellow, bgcolor=color.new(#363a45, 0), text_size=size.small)
            r += 1

            table.cell(mainPanel, 0, r, "DURUM / AŞAMA", text_color=color.gray, text_size=fSize)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, trailStatusShort, text_color=color.rgb(255, 215, 0), text_size=fSize, bgcolor=color.new(color.red, 60))
            r += 1

            if not na(nextTriggerLevelShort)
                table.cell(mainPanel, 0, r, "SIRADAKİ TETİK", text_color=color.gray, text_size=fSize)
                table.merge_cells(mainPanel, 1, r, 3, r)
                table.cell(mainPanel, 1, r, str.tostring(nextTriggerLevelShort, priceFormat), text_color=color.yellow, text_size=fSize)
                r += 1

                table.cell(mainPanel, 0, r, "ÖDÜL", text_color=color.gray, text_size=fSize)
                table.merge_cells(mainPanel, 1, r, 3, r)
                table.cell(mainPanel, 1, r, mentorMsgShort, text_color=color.aqua, text_size=fSize)
                r += 1

        // SHORT MATRIX
        if showMatrix and not mobilMode
            table.merge_cells(mainPanel, 0, r, 3, r)
            table.cell(mainPanel, 0, r, "--- 🔻 SHORT MINI-MATRIX ---", text_color=color.silver, bgcolor=color.new(#363a45, 0), text_size=size.small)
            r += 1

            string miniRow = (strongTrendShort ? "🟩HTF" : "🟥HTF") + " | " + (confidenceShort >= scoreReqShort ? "🟩SKOR" : "🟥SKOR") + " | " + (rrOkShort ? "🟩R:R" : "🟥R:R") + " | " + (adxOkShort ? "🟩ADX" : "🟥ADX") + " | " + (volRegime <= FINAL_VOL ? "🟩VOL" : "🟥VOL")
            table.cell(mainPanel, 0, r, "SATIR", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, miniRow, text_color=color.white, text_size=fSizeDetail)
            r += 1

        // SHORT SAFETY (ayrı gösterilecekse)
        if not mobilMode and not showSafetyOnce
            table.merge_cells(mainPanel, 0, r, 3, r)
            table.cell(mainPanel, 0, r, "🔌 SAFETY & RISK", text_color=color.silver, bgcolor=color.new(#363a45, 0), text_size=size.small)
            r += 1

            string circuitStatusS = SYSTEM_GREEN_LIGHT ? "🟢 OK" : "🔴 TRIGGERED"
            table.cell(mainPanel, 0, r, "CIRCUIT BREAKER", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, circuitStatusS, text_color=SYSTEM_GREEN_LIGHT ? color.green : color.red, text_size=fSizeDetail)
            r += 1

            string riskProfileTxtS = "Dynamic: %" + str.tostring(currentRiskPercent) + " (Base: " + str.tostring(FINAL_RISK_BASE) + " / Red: " + str.tostring(FINAL_RISK_RED) + " / Cap: " + str.tostring(maxLeverageCap) + "x)"
            table.cell(mainPanel, 0, r, "RISK PROFILE", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, riskProfileTxtS, text_color=color.white, text_size=fSizeDetail)
            r += 1

            string kellyTxtS = "Kelly (teorik): %" + str.tostring(kellySuggestedRiskPercent, "#.1") + " | Win: %" + str.tostring(cumulativeWinRate * 100.0, "#.1") + " / AvgR: " + str.tostring(cumulativeAvgRR, "#.2")
            table.cell(mainPanel, 0, r, "KELLY STATS", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, kellyTxtS, text_color=color.white, text_size=fSizeDetail)
            r += 1

            string riskHistTxtS = "MaxDD(trade): %" + str.tostring(maxDrawdownTrades, "#.1") + " / MaxLossStreak: " + str.tostring(maxConsecutiveLosses, "#")
            table.cell(mainPanel, 0, r, "RISK HISTORY", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, riskHistTxtS, text_color=color.white, text_size=fSizeDetail)
            r += 1
// =============================================================================
// BÖLÜM 10: STRATEJİ EMRİ + JSON/ALARM (V2 — EXIT DETAIL EKLENDİ)
// =============================================================================

// ta.* fonksiyonları global scope'ta olmalı
float val_ema200    = ta.ema(close, 200)
float avg_vol       = ta.sma(volume, 10)

string passphrase = "AKK_Guvenlik_2026"
string meta_version = "AKK_STR_V201.13"
string meta_symbol  = syminfo.ticker
string meta_mode    = tfName + " | " + marketName
string tStamp_json  = str.format("{0,date,dd.MM.yyyy HH:mm}", time + 10800000)

string val_trend    = close > val_ema200 ? "BOGA" : "AYI"
float val_vol_ratio = (avg_vol == 0 or na(avg_vol)) ? 0 : (volume / avg_vol) * 100

string json_technical =
     "\"technical\":{\"rsi\":" + str.tostring(nz(rsiVal), "#.1") +
     ",\"adx\":" + str.tostring(nz(adx), "#.1") +
     ",\"dist_sma200\":" + str.tostring(nz(((close - val_ema200)/val_ema200)*100), "#.2") +
     ",\"vol_regime\":" + str.tostring(nz(volRegime), "#.2") +
     ",\"vol_ratio\":" + str.tostring(nz(val_vol_ratio), "#.0") +
     ",\"trend\":\"" + val_trend + "\"}"

string json_meta =
     "\"meta\":{\"version\":\"" + meta_version +
     "\",\"symbol\":\"" + meta_symbol +
     "\",\"mode\":\"" + meta_mode +
     "\",\"timestamp\":\"" + tStamp_json + "\"}"

float long_tp1  = entryRalli + (riskUnit * 2.0)
float short_tp1 = entryRalliShort - (riskUnit * 2.0)

string json_trade_long =
     "\"trade\":{\"price\":" + str.tostring(nz(sRalli ? entryRalli : pusuLevel), "#.####") +
     ",\"stop\":" + str.tostring(nz(sRalli ? stopRalli : pusuStop), "#.####") +
     ",\"tp1\":" + str.tostring(nz(sRalli ? long_tp1 : pusuTP1), "#.####") +
     ",\"tp2\":" + str.tostring(nz(sRalli ? targetRalli : pusuTP2), "#.####") + "}"

string json_trade_short =
     "\"trade\":{\"price\":" + str.tostring(nz(sRalliShort ? entryRalliShort : pusuLevelShort), "#.####") +
     ",\"stop\":" + str.tostring(nz(sRalliShort ? stopRalliShort : pusuStopShort), "#.####") +
     ",\"tp1\":" + str.tostring(nz(sRalliShort ? short_tp1 : pusuTP1Short), "#.####") +
     ",\"tp2\":" + str.tostring(nz(sRalliShort ? targetRalliShort : pusuTP2Short), "#.####") + "}"

string json_analysis =
     "\"analysis\":{\"score\":" + str.tostring(nz(confidence / 10.0), "#.2") + "}"

string labelTextLongJson  = str.replace_all(str.replace_all(labelTextLong, "\"", "\\\""), "\n", "\\n")
string labelTextShortJson = str.replace_all(str.replace_all(labelTextShort, "\"", "\\\""), "\n", "\\n")
string labelTextExitJson  = str.replace_all(str.replace_all(labelTextExit, "\"", "\\\""), "\n", "\\n")

// ─── EXIT DETAIL BLOĞU (YENİ) ─────────────────────────────────────────────

string exitEngineType = lastTradeWasRalli ? "RALLI" : "PUSU"

string exitTypeLabel = "MANUAL"
if str.contains(logBitisNedeni, "HEDEF")
    exitTypeLabel := "TP2"
else if str.contains(logBitisNedeni, "TIMEOUT")
    exitTypeLabel := "TIMEOUT"
else if str.contains(logBitisNedeni, "STOP")
    if lastTradeSide == "LONG" and logCikisFiyati > logGirisFiyati
        exitTypeLabel := "TRAIL"
    else if lastTradeSide == "SHORT" and logCikisFiyati < logGirisFiyati
        exitTypeLabel := "TRAIL"
    else
        exitTypeLabel := "STOP"

float exitPnlPercent = logGirisFiyati != 0.0 ? ((logCikisFiyati - logGirisFiyati) / logGirisFiyati) * 100.0 : 0.0
if lastTradeSide == "SHORT"
    exitPnlPercent := logGirisFiyati != 0.0 ? ((logGirisFiyati - logCikisFiyati) / logGirisFiyati) * 100.0 : 0.0

int exitDurationBars = bar_index - logGirisBar

float exit_rrDen_i = na
float exit_rrDen_c = na
if lastTradeWasRalli
    if lastTradeSide == "SHORT"
        exit_rrDen_i := nz(initialStopRalliShort, stopRalliShort) - logGirisFiyati
        exit_rrDen_c := stopRalliShort - logGirisFiyati
    else
        exit_rrDen_i := logGirisFiyati - nz(initialStopRalli, stopRalli)
        exit_rrDen_c := logGirisFiyati - stopRalli
else
    if lastTradeSide == "SHORT"
        exit_rrDen_i := nz(pusuInitialStopShort, pusuStopShort) - logGirisFiyati
        exit_rrDen_c := nz(activeSlShort, pusuStopShort) - logGirisFiyati
    else
        exit_rrDen_i := logGirisFiyati - nz(pusuInitialStop, pusuStop)
        exit_rrDen_c := logGirisFiyati - nz(activeSl, pusuStop)

float exit_r_initial = (exit_rrDen_i == 0.0 or na(exit_rrDen_i)) ? 0.0 : math.abs((logCikisFiyati - logGirisFiyati) / exit_rrDen_i)
float exit_r_current = (exit_rrDen_c == 0.0 or na(exit_rrDen_c)) ? 0.0 : math.abs((logCikisFiyati - logGirisFiyati) / exit_rrDen_c)

float peakR_val = 0.0
if lastTradeWasRalli
    if lastTradeSide == "LONG" and exit_rrDen_i != 0.0 and not na(exit_rrDen_i)
        peakR_val := math.abs((peakRalli - logGirisFiyati) / exit_rrDen_i)
    else if lastTradeSide == "SHORT" and exit_rrDen_i != 0.0 and not na(exit_rrDen_i)
        peakR_val := math.abs((logGirisFiyati - troughRalliShort) / exit_rrDen_i)

string exitTrailStage = lastTradeSide == "LONG" ? trailStatus : trailStatusShort

int totalTrades = array.size(tradeWins)
int totalWins = 0
if totalTrades > 0
    for i = 0 to totalTrades - 1
        if array.get(tradeWins, i)
            totalWins += 1
float cumWinRate = totalTrades > 0 ? (totalWins * 1.0 / totalTrades) * 100.0 : 0.0

string json_exit_detail =
     "\"exit_detail\":{" +
     "\"entry_price\":" + str.tostring(nz(logGirisFiyati), "#.####") +
     ",\"exit_price\":" + str.tostring(nz(logCikisFiyati), "#.####") +
     ",\"exit_type\":\"" + exitTypeLabel + "\"" +
     ",\"side\":\"" + lastTradeSide + "\"" +
     ",\"engine\":\"" + exitEngineType + "\"" +
     ",\"pnl_percent\":" + str.tostring(nz(exitPnlPercent), "#.##") +
     ",\"r_initial\":" + str.tostring(nz(exit_r_initial), "#.##") +
     ",\"r_current\":" + str.tostring(nz(exit_r_current), "#.##") +
     ",\"peak_r\":" + str.tostring(nz(peakR_val), "#.##") +
     ",\"duration_bars\":" + str.tostring(nz(exitDurationBars)) +
     ",\"trail_stage\":\"" + exitTrailStage + "\"" +
     ",\"cumulative\":{\"total\":" + str.tostring(totalTrades) +
     ",\"wins\":" + str.tostring(totalWins) +
     ",\"win_rate\":" + str.tostring(nz(cumWinRate), "#.#") +
     ",\"avg_r\":" + str.tostring(nz(cumulativeAvgRR), "#.##") +
     ",\"kelly\":" + str.tostring(nz(kellySuggestedRiskPercent), "#.#") +
     ",\"max_dd\":" + str.tostring(nz(maxDrawdownTrades), "#.#") + "}}"

// ─── GİRİŞ JSON'LARI ──────────────────────────────────────────────────────

string json_entry_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"buy\",\"side\":\"LONG\",\"event\":\"ENTRY\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_technical + "," + json_meta + "," + json_trade_long + "," + json_analysis +
     ",\"label_text\":\"" + labelTextLongJson + "\"}"

string json_entry_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"sell\",\"side\":\"SHORT\",\"event\":\"ENTRY\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_technical + "," + json_meta + "," + json_trade_short + "," + json_analysis +
     ",\"label_text\":\"" + labelTextShortJson + "\"}"

// ─── ÇIKIŞ JSON'LARI (exit_detail EKLENDİ) ────────────────────────────────

string json_exit_stop_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"sell\",\"side\":\"LONG\",\"event\":\"EXIT\",\"reason\":\"STOP\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_tp2_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"sell\",\"side\":\"LONG\",\"event\":\"EXIT\",\"reason\":\"TP2\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_manual_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"sell\",\"side\":\"LONG\",\"event\":\"EXIT\",\"reason\":\"MANUAL\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_timeout_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"sell\",\"side\":\"LONG\",\"event\":\"EXIT\",\"reason\":\"TIMEOUT\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_stop_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"buy\",\"side\":\"SHORT\",\"event\":\"EXIT\",\"reason\":\"STOP\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_tp2_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"buy\",\"side\":\"SHORT\",\"event\":\"EXIT\",\"reason\":\"TP2\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_manual_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"buy\",\"side\":\"SHORT\",\"event\":\"EXIT\",\"reason\":\"MANUAL\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"

string json_exit_timeout_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"buy\",\"side\":\"SHORT\",\"event\":\"EXIT\",\"reason\":\"TIMEOUT\",\"comment\":\"{{strategy.order.comment}}\",\"close\":" +
     str.tostring(close) + "," + json_exit_detail + ",\"meta\":{\"mode\":\"" + meta_mode + "\"},\"label_text\":\"" + labelTextExitJson + "\"}"
// =============================================================================
// STRATEJİ EMRİ (Entry/Exit)
// =============================================================================

float plannedStopLong = sRalli ? (close - riskUnit) : (sPusu ? pusuStop : na)
float plannedStopShort = sRalliShort ? (close + riskUnit) : (sPusuShort ? pusuStopShort : na)

float riskDollarLong = strategy.equity * (currentRiskPercent / 100.0)
float riskDollarShort = strategy.equity * (shortRiskPercent / 100.0)

float distanceToStopLong = na(plannedStopLong) ? na : math.abs(close - plannedStopLong)
float targetQtyLong = (not na(distanceToStopLong) and distanceToStopLong > 0.0) ? (riskDollarLong / distanceToStopLong) : 0.0

float distanceToStopShort = na(plannedStopShort) ? na : math.abs(close - plannedStopShort)
float targetQtyShort = (not na(distanceToStopShort) and distanceToStopShort > 0.0) ? (riskDollarShort / distanceToStopShort) : 0.0

float maxAllowedQty = (strategy.equity * maxLeverageCap) / close
float finalQtyLong = math.min(targetQtyLong, maxAllowedQty)
float finalQtyShort = math.min(targetQtyShort, maxAllowedQty)

bool blockAlert = dailyLimitBreached and (allowLong or allowShort)

bool canEnterLong = allowLong and not blockAlert and barstate.isconfirmed and strategy.position_size == 0
bool canEnterShort = allowShort and not blockAlert and barstate.isconfirmed and strategy.position_size == 0

// --- ETİKET BAZLI ALARM ---
bool labelLongSignal  = showLabels and showLongUI and allowLong and (signalRalli or signalPusu) and barstate.isconfirmed
bool labelShortSignal = showLabels and showShortUI and allowShort and (signalRalliShort or signalPusuShort) and barstate.isconfirmed

bool labelLongFire  = labelLongSignal  and not labelLongSignal[1]
bool labelShortFire = labelShortSignal and not labelShortSignal[1]

bool exitFire      = tradeBitti and not tradeBitti[1] and barstate.isconfirmed
bool exitLongFire  = exitFire and lastTradeSide == "LONG"
bool exitShortFire = exitFire and lastTradeSide == "SHORT"

bool exitIsStop    = str.contains(logBitisNedeni, "STOP")
bool exitIsTp2     = str.contains(logBitisNedeni, "HEDEF")
bool exitIsTimeout = str.contains(logBitisNedeni, "TIMEOUT")
bool exitIsManual  = not exitIsStop and not exitIsTp2 and not exitIsTimeout

if labelLongFire
    alert(json_entry_long, alert.freq_once_per_bar_close)

if labelShortFire
    alert(json_entry_short, alert.freq_once_per_bar_close)

if exitLongFire
    string exitJson = exitIsStop ? json_exit_stop_long : exitIsTp2 ? json_exit_tp2_long : exitIsTimeout ? json_exit_timeout_long : json_exit_manual_long
    alert(exitJson, alert.freq_once_per_bar_close)

if exitShortFire
    string exitJsonS = exitIsStop ? json_exit_stop_short : exitIsTp2 ? json_exit_tp2_short : exitIsTimeout ? json_exit_timeout_short : json_exit_manual_short
    alert(exitJsonS, alert.freq_once_per_bar_close)

if canEnterLong
    strategy.entry("Long", strategy.long, qty=finalQtyLong, comment="AL", alert_message=json_entry_long)

if canEnterShort
    strategy.entry("Short", strategy.short, qty=finalQtyShort, comment="SAT", alert_message=json_entry_short)

// Long exits (Ayrı exit ID'leri: TP ve STOP farklı webhook JSON gönderir — Pine v5 geçerli pattern)
if strategy.position_size > 0
    if inPositionPusu
        strategy.exit("Exit Pusu TP2", "Long", limit=trackedT2, comment_profit="PUSU_TP", alert_message=json_exit_tp2_long)
        strategy.exit("Exit Pusu STOP", "Long", stop=activeSl, comment_loss="PUSU_STOP", alert_message=json_exit_stop_long)
    else if inTradeRalli
        strategy.exit("Exit Ralli TP2", "Long", limit=targetRalli, comment_profit="RALLI_TP", alert_message=json_exit_tp2_long)
        strategy.exit("Exit Ralli STOP", "Long", stop=stopRalli, comment_loss="RALLI_STOP", alert_message=json_exit_stop_long)

// Short exits (Ayrı exit ID'leri: TP ve STOP farklı webhook JSON gönderir)
if strategy.position_size < 0
    if inPositionPusuShort
        strategy.exit("Exit Pusu Short TP2", "Short", limit=trackedT2Short, comment_profit="PUSU_TP", alert_message=json_exit_tp2_short)
        strategy.exit("Exit Pusu Short STOP", "Short", stop=activeSlShort, comment_loss="PUSU_STOP", alert_message=json_exit_stop_short)
    else if inTradeRalliShort
        strategy.exit("Exit Ralli Short TP2", "Short", limit=targetRalliShort, comment_profit="RALLI_TP", alert_message=json_exit_tp2_short)
        strategy.exit("Exit Ralli Short STOP", "Short", stop=stopRalliShort, comment_loss="RALLI_STOP", alert_message=json_exit_stop_short)

// --- ALARM TEST MODU ---
if alarmTestModu and barstate.isconfirmed
    string testJson = "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol + "\",\"action\":\"test\",\"event\":\"TEST\",\"comment\":\"ALARM_TEST\",\"close\":" + str.tostring(close) + ",\"meta\":{\"mode\":\"" + meta_mode + "\"}}"
    alert(testJson, alert.freq_once_per_bar_close)

// --- TP1 INFO ALERT + ETİKET (FIX #7) ---
var bool tp1AlertedLong  = false
var bool tp1AlertedShort = false

if canEnterLong or canEnterShort
    tp1AlertedLong  := false
    tp1AlertedShort := false

bool tp1LongHit = (strategy.position_size > 0) and not tp1AlertedLong and dataHigh >= (sRalli ? long_tp1 : pusuTP1)
bool tp1ShortHit = (strategy.position_size < 0) and not tp1AlertedShort and dataLow <= (sRalliShort ? short_tp1 : pusuTP1Short)

string json_tp1_long =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"info\",\"side\":\"LONG\",\"event\":\"TP1\",\"reason\":\"TP1\",\"comment\":\"TP1_INFO\",\"close\":" + str.tostring(close) +
     ",\"meta\":{\"mode\":\"" + meta_mode + "\"}}"

string json_tp1_short =
     "{\"passphrase\":\"" + passphrase + "\",\"ticker\":\"" + meta_symbol +
     "\",\"action\":\"info\",\"side\":\"SHORT\",\"event\":\"TP1\",\"reason\":\"TP1\",\"comment\":\"TP1_INFO\",\"close\":" + str.tostring(close) +
     ",\"meta\":{\"mode\":\"" + meta_mode + "\"}}"

if tp1LongHit
    tp1AlertedLong := true
    alert(json_tp1_long)
    // FIX #7: TP1 etiketi
    if showLabels and showLongUI
        string tp1Txt = "TP1 🎯\n" + str.tostring(close, priceFormat)
        label.new(bar_index, dataHigh, tp1Txt, style=label.style_label_down, color=color.new(#FFD600, 0), textcolor=color.black, size=size.small)

if tp1ShortHit
    tp1AlertedShort := true
    alert(json_tp1_short)
    // FIX #7: TP1 etiketi (SHORT)
    if showLabels and showShortUI
        string tp1TxtS = "TP1 🎯\n" + str.tostring(close, priceFormat)
        label.new(bar_index, dataLow, tp1TxtS, style=label.style_label_up, color=color.new(#FFD600, 0), textcolor=color.black, size=size.small)

// --- LİVE PANEL ---
var label livePanel = label.new(bar_index, close, "", style=label.style_label_left, color=color.new(color.blue, 15), textcolor=color.white, size=size.small)

if barstate.islast and showLivePanel
    string riskStatus = (currentRiskPercent == FINAL_RISK_RED) ? "DEFANSIF (VOLATIL)" : "STANDART"
    string p_txt = "V1.6_UNIVERSAL\nMod: " + riskStatus + "\nRisk: %" + str.tostring(currentRiskPercent, "#.2") + "\nADX: " + str.tostring(adx, "#.1")

    label.set_xy(livePanel, bar_index + 4, close)
    label.set_text(livePanel, p_txt)
// === AKK_WATCH_V201.13_CDX_FULL — SON ===
