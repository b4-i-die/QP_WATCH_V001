        table.cell(mainPanel, 0, r, "R:R (TP1)", text_color=color.gray, text_size=fSize)
        table.merge_cells(mainPanel, 1, r, 3, r)
        table.cell(mainPanel, 1, r, str.tostring(rr1, "#.##") + " / " + str.tostring(dynamicRrThresh, "#.##"), text_color=rrOk ? color.white : color.red, text_size=fSize)
        r += 1

        // RALLİ
        table.merge_cells(mainPanel, 0, r, 3, r)
        table.cell(mainPanel, 0, r, "⚔️ RALLİ (HÜCUM)", text_color=color.silver, bgcolor=color.new(#363a45, 0), text_size=size.small)
        r += 1

        if inTradeRalli
            table.cell(mainPanel, 0, r, "GÜNCEL FİYAT", text_color=color.gray, text_size=fSize)
