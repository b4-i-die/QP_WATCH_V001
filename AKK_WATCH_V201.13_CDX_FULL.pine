    else if tfKey == "240"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.5
        sym_RiskMult := 0.8
        sym_AdxAdd := 5
        sym_StopAtrMult := 1.0

else if symbolKey == "PAXGTRY"
    if tfKey == "30"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.5
        sym_RiskMult := 0.8
        sym_AdxAdd := 5
        sym_StopAtrMult := 1.0
    else if tfKey == "60"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.5
        sym_RiskMult := 0.8
        sym_AdxAdd := 5
        sym_StopAtrMult := 1.0
    else if tfKey == "240"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.5
        sym_RiskMult := 0.8
        sym_AdxAdd := 5
