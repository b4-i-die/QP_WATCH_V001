            r += 1

            table.cell(mainPanel, 0, r, "VOLATİLİTE", text_color=color.gray, text_size=fSizeDetail)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, "VOL: " + str.tostring(volRegime, "#.2") + " / Th: " + str.tostring(FINAL_VOL, "#.2"), text_color=volRegime > FINAL_VOL ? color.orange : color.green, text_size=fSizeDetail)
            r += 1

    // --- SHORT BÖLÜMÜ ---
    if showShortUI
        table.merge_cells(mainPanel, 0, r, 3, r)
        table.cell(mainPanel, 0, r, showLongUI ? "AKK_STR_V201.13 (SHORT)" : "AKK_STR_V201.13", text_color=color.white, bgcolor=color.new(color.blue, 40), text_size=fSize)
        r += 1

        if not showSharedHeader
            color modeColorS = (tfName == "🛡️ SNIPER (1H)") ? color.orange : (tfName == "👑 TREND KING (8H+)" ? color.green : color.blue)
            table.cell(mainPanel, 0, r, "AKTİF MOD", text_color=color.gray, text_size=fSize)
            table.merge_cells(mainPanel, 1, r, 3, r)
            table.cell(mainPanel, 1, r, tfName, text_color=modeColorS, text_size=fSize, bgcolor=color.new(modeColorS, 90))
            r += 1

