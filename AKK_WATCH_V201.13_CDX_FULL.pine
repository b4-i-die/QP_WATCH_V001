            string ok_row = (strongTrend ? "🟩HTF " : "🟥HTF ") + (confidence >= scoreReq ? "🟩SKOR " : "🟥SKOR ") + ((wiz_gate and not mesafeVeto) ? "🟩MOM " : "🟥MOM ") + (rrOk ? "🟩R:R" : "🟥R:R")
            table.cell(mainPanel, 0, r, "FİLTRELER", text_color=color.gray, text_size=fSizeDetail)
