    else if tfKey == "240"
        hasSymbolTfOverride := true
        sym_TargetMult := 1.0
        sym_RiskMult := 1.0
        sym_AdxAdd := 0
        sym_StopAtrMult := 1.0

else if symbolKey == "XAGUSD"
